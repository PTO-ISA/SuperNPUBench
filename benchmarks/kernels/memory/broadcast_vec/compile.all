#! /bin/bash
make    TESTCASE=broadcast_vec_07 DType=__half tMs=32 MAX_DIMs=2 \
        IN_SHAPEs=1443,1 OUT_SHAPEs=1443,129 IN_DIMs=2 OUT_DIMs=2 \
        gIMs=1443*1 gOMs=1443*129 \
        TESTNAME=broadcast_vec_to_07 \
        IN_SHAPE_NAME=1443_1 OUT_SHAPE_NAME=1443_129 res_check=off diss

