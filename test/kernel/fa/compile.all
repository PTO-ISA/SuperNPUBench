#!/bin/bash
# Flash Attention test cases

# flash_attention basic tests
make TESTCASE=flash_attention MODE=ALL B=1 S=32 D=256 tM=16 tK=16
make TESTCASE=flash_attention MODE=ALL B=1 S=64 D=256 tM=32 tK=32
make TESTCASE=flash_attention MODE=ALL B=1 S=128 D=256 tM=16 tK=16
make TESTCASE=flash_attention MODE=ALL B=1 S=256 D=256 tM=32 tK=32

# fa_HIF4_HIF4 tests
make TESTCASE=fa_HIF4_HIF4 MODE=BF16 Sq=256 Skv=512 Tm=128 Tk=128 X=1 Y=1
make TESTCASE=fa_HIF4_HIF4 MODE=BF16x2 Sq=256 Skv=512 Tm=128 Tk=128 X=1 Y=1
make TESTCASE=fa_HIF4_HIF4 MODE=BF16x2_NOGATHER Sq=256 Skv=512 Tm=128 Tk=128 X=1 Y=1
