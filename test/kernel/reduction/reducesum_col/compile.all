#!/bin/bash
# Reducesum column-wise reduction test cases

COMPILER_DIR=${COMPILER_DIR:-/Users/liyi/Documents/SuperNPU编译器构建/output/linx_blockisa_llvm_musl/bin}

# Large matrix, int32_t
make TESTCASE=reducesum_col COMPILER_DIR=$COMPILER_DIR DType=int32_t tM_s=32 tN_s=128 \
    gM_s=8192 gN_s=1024

# Large matrix, __half
make TESTCASE=reducesum_col COMPILER_DIR=$COMPILER_DIR DType=__half tM_s=32 tN_s=128 \
    gM_s=8192 gN_s=1024
