#!/bin/bash
# Broadcast operator test cases

# ============================================
# broadcast_07: 2D broadcast (1334,1) -> (1334,129)
# ============================================
make TESTCASE=broadcast_07 DType=__half tMs=2048 MAX_DIMs=2 \
    IN_SHAPEs=1334,1 OUT_SHAPEs=1334,129 IN_DIMs=2 OUT_DIMs=2 \
    gIMs=1334*1 gOMs=1334*129 \
    IN_SHAPE_NAME=1334_1 OUT_SHAPE_NAME=1334_129

# ============================================
# broadcast_019: 3D broadcast (1280,1,49) -> (1280,8,49)
# ============================================
make TESTCASE=broadcast_019 DType=__half tMs=2048 MAX_DIMs=3 \
    IN_SHAPEs=1280,1,49 OUT_SHAPEs=1280,8,49 IN_DIMs=3 OUT_DIMs=3 \
    gIMs=1280*1*49 gOMs=1280*8*49 \
    IN_SHAPE_NAME=1280_1_49 OUT_SHAPE_NAME=1280_8_49

# ============================================
# broadcast_Hunyuan: 5D broadcast (1,1,1,65,128) -> (1,1,7,65,128)
# ============================================
make TESTCASE=broadcast_Hunyuan DType=__half tMs=2048 MAX_DIMs=5 \
    IN_SHAPEs=1,1,1,65,128 OUT_SHAPEs=1,1,7,65,128 IN_DIMs=5 OUT_DIMs=5 \
    gIMs=1*1*1*65*128 gOMs=1*1*7*65*128 \
    IN_SHAPE_NAME=1_1_1_65_128 OUT_SHAPE_NAME=1_1_7_65_128

# ============================================
# broadcast_039: 4D broadcast variants
# ============================================
make TESTCASE=broadcast_039 DType=__half tMs=2048 MAX_DIMs=4 \
    IN_SHAPEs=1,128,1,16 OUT_SHAPEs=64,128,8,16 IN_DIMs=4 OUT_DIMs=4 \
    gIMs=1*128*1*16 gOMs=64*128*8*16 \
    IN_SHAPE_NAME=1_128_1_16 OUT_SHAPE_NAME=64_128_8_16

make TESTCASE=broadcast_039 DType=__half tMs=2048 MAX_DIMs=4 \
    IN_SHAPEs=1,8192,1,16 OUT_SHAPEs=1,8192,8,16 IN_DIMs=4 OUT_DIMs=4 \
    gIMs=1*8192*1*16 gOMs=1*8192*8*16 \
    IN_SHAPE_NAME=1_8192_1_16 OUT_SHAPE_NAME=1_8192_8_16

# ============================================
# broadcast_vec: Vectorized broadcast variants
# ============================================
make TESTCASE=broadcast_vec_07 DType=__half tMs=32 MAX_DIMs=2 \
    IN_SHAPEs=1443,1 OUT_SHAPEs=1443,129 IN_DIMs=2 OUT_DIMs=2 \
    gIMs=1443*1 gOMs=1443*129 \
    IN_SHAPE_NAME=1443_1 OUT_SHAPE_NAME=1443_129

make TESTCASE=broadcast_vec_019 DType=__half tMs=16 MAX_DIMs=3 \
    IN_SHAPEs=1280,1,49 OUT_SHAPEs=1280,8,49 IN_DIMs=3 OUT_DIMs=3 \
    gIMs=1280*1*49 gOMs=1280*8*49 \
    IN_SHAPE_NAME=1280_1_49 OUT_SHAPE_NAME=1280_8_49

make TESTCASE=broadcast_vec_039 DType=__half tMs=16 MAX_DIMs=3 \
    IN_SHAPEs=8192,1,16 OUT_SHAPEs=8192,8,16 IN_DIMs=3 OUT_DIMs=3 \
    gIMs=8192*1*16 gOMs=8192*8*16 \
    IN_SHAPE_NAME=8192_1_16 OUT_SHAPE_NAME=8192_8_16
