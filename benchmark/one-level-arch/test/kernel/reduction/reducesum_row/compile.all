#!/bin/bash
# Reducesum row-wise reduction test cases

: "${COMPILER_DIR:?Set COMPILER_DIR to the in-repo Linx compiler bin directory}"

# Large matrix, int32_t
make TESTCASE=reducesum_row COMPILER_DIR=$COMPILER_DIR DType=int32_t tM_s=16 tN_s=128 \
    gM_s=16 gN_s=8192

# Large matrix, __half (DISABLED: Tile alignment < 32 bytes for _Float16 with Cols=8)
# make TESTCASE=reducesum_row COMPILER_DIR=$COMPILER_DIR DType=__half tM_s=16 tN_s=128 \
#     gM_s=16 gN_s=8192
