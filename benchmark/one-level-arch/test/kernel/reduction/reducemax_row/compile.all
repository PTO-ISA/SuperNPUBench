#!/bin/bash
# Reducemax row-wise reduction test cases

COMPILER_DIR=${COMPILER_DIR:-/Users/liyi/Documents/SuperNPU编译器构建/output/linx_blockisa_llvm_musl/bin}

# Large matrix, int32_t
make TESTCASE=reducemax_row COMPILER_DIR=$COMPILER_DIR DType=int32_t tM_s=16 tN_s=128 \
    gM_s=16 gN_s=8192

