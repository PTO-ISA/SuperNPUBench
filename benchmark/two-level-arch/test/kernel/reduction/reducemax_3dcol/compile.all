#!/bin/bash
# Reducesum column-wise reduction test cases


: "${COMPILER_DIR:?Set COMPILER_DIR to the in-repo Linx compiler bin directory}"

# Large matrix, __half
make TESTCASE=reducemax_3dcol COMPILER_DIR=$COMPILER_DIR  DType=__half tM_s=128 tN_s=8 tM_VLDs=120 \
     Num=381 gM_s=120 gN_s=8 \
     PLAT=linx
