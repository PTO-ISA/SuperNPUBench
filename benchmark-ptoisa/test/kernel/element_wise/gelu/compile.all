#!/bin/bash
# GELU operator test cases
# Typical scenarios: different data types, shapes, and approximation modes


# ============================================
# BF16, exact mode
# ============================================
# 3D shape: (24, 8, 1024)
make TESTCASE=gelu DTYPE=pto_bf16_t tMs=2048 gMs=24*8*1024 \
    SHAPE_NAME=24_8_1024 Approximate=false diss

